    "tailwindcss": "^4.2.0",
    "typescript": "catalog:"
  },
  "knip": {
    "ignoreBinaries": [
      "oxlint",
      "oxfmt",
      "knip"
    ],
    "ignoreIssues": {
      "src/components/ui/**": [
