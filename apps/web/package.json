    "ai": "^6.0.97",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "catalog:",
    "gt-next": "^6.12.16",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.6",
