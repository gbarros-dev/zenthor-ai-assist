{
  "name": "@zenthor-ai-assist/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "convex dev",
    "dev:setup": "convex dev --configure --until-success",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "bunx @typescript/native-preview -p convex/tsconfig.json --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix --allow-remove-files",
    "clean": "git clean -xdf .cache .turbo node_modules convex/_generated"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clerk/backend": "^2.32.0",
    "@mariozechner/pi-agent-core": "^0.54.2",
    "@mariozechner/pi-ai": "^0.54.2",
    "convex": "catalog:",
    "convex-helpers": "^0.1.113",
    "svix": "^1.85.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260221.1",
    "typescript": "catalog:"
  },
  "knip": {
    "ignoreBinaries": [
      "oxlint",
      "oxfmt",
      "knip"
    ],
    "ignore": [
      "convex/**/*.test.ts",
      "tests/_test-fakes.ts",
      "tests/_test-run.ts"
    ]
  }
}
