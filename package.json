{
  "name": "zenthor-ai-assist",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/node": "^25.3.0",
      "convex": "^1.32.0",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "check": "oxlint && oxfmt --check",
    "check:fix": "oxlint --fix && oxfmt --write",
    "typecheck": "turbo run typecheck",
    "knip": "turbo run knip --continue",
    "knip:fix": "turbo run knip:fix --continue",
    "static-analysis": "turbo run lint format:check typecheck knip --continue",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "clean:workspaces": "turbo run clean"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "catalog:",
    "@zenthor-ai-assist/config": "workspace:*",
    "knip": "^5.85.0",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "turbo": "^2.8.10",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.9"
}
